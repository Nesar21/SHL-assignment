# SHL Assessment Advisor — Environment Variables
# Copy this file to .env and fill in your values.

# Required: Google AI Studio API key for Gemini 3.1 Flash Lite
GEMINI_API_KEY=your_api_key_here

# Optional: Override model (default: gemini-3.1-flash-lite)
# MODEL_NAME=gemini-3.1-flash-lite

# Optional: test_type format (default: comma-separated like "A,S")
# Set to "true" for single primary code only (e.g. "A")
# TEST_TYPE_PRIMARY_ONLY=false

# Optional: description truncation (default: 40 words)
# DESCRIPTION_MAX_WORDS=40

# Optional: catalog path (default: shl_product_catalog.json at project root)
# CATALOG_PATH=shl_product_catalog.json
